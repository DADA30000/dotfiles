+#include <iostream>
 #include <ranges>
 
 // Default value is half the compositor margin
@@ -141,6 +142,13 @@ void app_pacer::predict(int64_t now_ns,
 
 	if (cpu_time > period or gpu_time > period or (min_ready > last_display_time and min_ready < last_display_time + period))
 	{
+		std::cerr << "[Pacer Skip!] Frame: " << frame_id
+		          << " | min_ready: " << min_ready
+		          << " | last_display_time: " << last_display_time
+		          << " | cpu_time: " << (cpu_time / 1e6) << "ms"
