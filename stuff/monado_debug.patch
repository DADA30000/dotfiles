 #include "comp_vk_client.h"
 
+#include <stdio.h>
+#include <stdint.h>
+#include <unistd.h>
+#include <sys/types.h>
+
+// Макрос обертывает вызов функции, замеряет время и сохраняет в уникальный буфер.
+// #name автоматически превращает имя в строку для CSV.
+#define PROFILE_CALL(log_name, code_to_run)                                                                            \
+	do {                                                                                                           \
+		static uint64_t _prof_buf[2000];                                                                       \
+		static size_t _prof_count = 0;                                                                         \
+		uint64_t _start_ns = os_monotonic_get_ns();                                                            \
+                                                                                                                       \
+		code_to_run; /* <-- Здесь выполняется оригинальный вызов */                                            \
+                                                                                                                       \
+		uint64_t _duration_ns = os_monotonic_get_ns() - _start_ns;                                             \
+		if (_prof_count < 2000) {                                                                              \
+			_prof_buf[_prof_count++] = _duration_ns;                                                       \
+		} else {                                                                                               \
+			char filename[256];                                                                            \
+			snprintf(filename, sizeof(filename), "/tmp/monado_log_%d.csv", getpid());                      \
+			FILE *f = fopen(filename, "a");                                                                \
+			if (f) {                                                                                       \
+				for (size_t i = 0; i < 2000; ++i) {                                                    \
+					fprintf(f, "%s,%llu\n", #log_name, (unsigned long long)_prof_buf[i]);          \
+				}                                                                                      \
+				fclose(f);                                                                             \
+			}                                                                                              \
+			_prof_count = 0;                                                                               \
+			_prof_buf[_prof_count++] = _duration_ns;                                                       \
+		}                                                                                                      \
+	} while (0)
+
 // Prefixed with OXR since the only user right now is the OpenXR state tracker.
 DEBUG_GET_ONCE_LOG_OPTION(vulkan_log, "OXR_VULKAN_LOG", U_LOGGING_INFO)
 
