@@ -588,3 +630,22 @@ printDuration diff
 
 timeDiffSeconds :: Int -> Text
 timeDiffSeconds = printDuration . fromIntegral
+
+printBytes :: Int -> Text
+printBytes bytes
+  | bytes < 1024 = show bytes <> " B"
+  | bytes < 1024 * 1024 = showDouble (fromIntegral bytes / 1024) <> " KiB"
+  | bytes < 1024 * 1024 * 1024 = showDouble (fromIntegral bytes / (1024 * 1024)) <> " MiB"
+  | otherwise = showDouble (fromIntegral bytes / (1024 * 1024 * 1024)) <> " GiB"
+ where
+  showDouble :: Double -> Text
+  showDouble val = fromString $ printf "%.1f" val
+
+urlToHost :: Text -> Maybe Host
+urlToHost url =
+  let (schema, suffix) = Text.breakOn "://" url
+  in if Text.null suffix
+       then Nothing
+       else
+         let hostPart = fst $ Text.breakOn "/" (Text.drop 3 suffix)
+         in if Text.null hostPart then Nothing else Just (Host (schema <> "://" <> hostPart))
