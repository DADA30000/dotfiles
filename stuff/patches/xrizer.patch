From efd4f5c016e204c5d740704f7bdb42f3f0d9577b Mon Sep 17 00:00:00 2001
From: Mats Huesmann <huesmann.mats@gmail.com>
Date: Mon, 18 May 2026 07:18:54 +0200
Subject: [PATCH 05/11] input: add pinch support to knuckles interaction
 profile

---
 src/input/profiles.rs          |  4 +++-
 src/input/profiles/knuckles.rs | 13 +++++++++++++
 2 files changed, 16 insertions(+), 1 deletion(-)

diff --git a/src/input/profiles.rs b/src/input/profiles.rs
index c3dec0e5..c0b322ca 100644
--- a/src/input/profiles.rs
+++ b/src/input/profiles.rs
@@ -541,7 +541,8 @@ pub mod paths {
         Squeeze::<Click, Value, Force, Touch>,
         Thumbstick::<Click, Touch, Vec2X, Vec2Y>,
         Trackpad::<Click, Touch, Force, Vec2X, Vec2Y>,
-        Thumbrest::<Touch>
+        Thumbrest::<Touch>,
+        Pinch::<Value, Force, Touch>
     );
 
     // Vec2 impls
@@ -561,6 +562,7 @@ pub mod paths {
                 "thumbstick" | "joystick" => Some(Self::Thumbstick),
                 "thumbrest" => Some(Self::Thumbrest),
                 "trackpad" => Some(Self::Trackpad),
+                "pinch" => Some(Self::Pinch),
                 _ => None,
             }
         }
diff --git a/src/input/profiles/knuckles.rs b/src/input/profiles/knuckles.rs
index 2c27a5c6..c8e48838 100644
--- a/src/input/profiles/knuckles.rs
+++ b/src/input/profiles/knuckles.rs
@@ -85,6 +85,19 @@ impl InteractionProfile for Knuckles {
                 component: Some(DynComponent::Touch),
                 ..
             } => Some(p.with_component(DynComponent::Value)),
+            DynInputPath {
+                subpath: DynSubpath::Pinch,
+                component: Some(component @ (DynComponent::Force | DynComponent::Value | DynComponent::Touch)),
+                ..
+            } => Some(DynInputPath {
+                subpath: match component {
+                    DynComponent::Force => DynSubpath::Trackpad,
+                    DynComponent::Value => DynSubpath::Trigger,
+                    DynComponent::Touch => DynSubpath::Thumbrest,
+                    _ => unreachable!(),
+                },
+                ..path
+            }),
             _ => None,
         }
     }

