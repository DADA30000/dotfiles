diff --git a/src/_sass/_colors.scss b/src/_sass/_colors.scss
index 0af230c..f3270e3 100644
--- a/src/_sass/_colors.scss
+++ b/src/_sass/_colors.scss
@@ -182,4 +182,16 @@ $titlebar-divider:                      on($titlebar, divider);
 $titlebar-fill:                         on($titlebar, fill);
 
 // workaround for GTK3 @placeholder_text_color which doesn't allow translucent colors
-$placeholder_text_color:                if($variant == 'light', mix(black, $base, percentage(0.6)), mix(white, $base, percentage(0.7)));
+$placeholder_text_color:                if($variant == 'light', $grey-600, $grey-500);
+
+// Force 0.01 deep transparency for all backgrounds in the Dark Variant
+@if $variant == 'dark' {
+  $background:                          rgba(#333333, 0.01);
+  $surface:                             rgba(#3C3C3C, 0.01);
+  $base:                                rgba(#2B2B2B, 0.01);
+  $base-alt:                            rgba(#303030, 0.01);
+  $titlebar:                            rgba(#202020, 0.01);
+  $titlebar-backdrop:                   rgba(#2C2C2C, 0.01);
+  $menu:                                rgba(#3C3C3C, 0.01);
+  $panel:                               rgba(#1F1F1F, 0.01);
+}
